{
  "name": "@selatropdev/thaurus",
  "version": "1.0.5",
  "description": "Thaurus E2E test automation project built on Thaurus",
  "bin": {
    "thaurus-setup": "bin/thaurus-setup.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/selatropdev/thaurus.git"
  },
  "homepage": "https://github.com/selatropdev/thaurus#readme",
  "bugs": {
    "url": "https://github.com/selatropdev/thaurus/issues"
  },
  "type": "module",
  "files": [
    "bin",
    "src",
    "playwright.config.ts",
    "globals.d.ts",
    "typings",
    "tsconfig.json",
    "context-docs",
    ".claude"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "package": "npm run build && npm pack",
    "prepublishOnly": "npm run build",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "allure:setup": "rimraf allure-results allure-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.2"
  }
}
